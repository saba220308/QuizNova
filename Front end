<script>
// ══ STORAGE ══
const DB={
  g:(k,d)=>{try{const v=localStorage.getItem(k);return v!=null?JSON.parse(v):d;}catch{return d;}},
  s:(k,v)=>localStorage.setItem(k,JSON.stringify(v))
};
const gT=()=>DB.g('nova_t',{});
const gS=()=>DB.g('nova_s',{});
const gC=()=>DB.g('nova_c',[]);
const gTests=()=>DB.g('nova_tests',[]);
const gRes=()=>DB.g('nova_res',[]);
const sT=v=>DB.s('nova_t',v);
const sS=v=>DB.s('nova_s',v);
const sC=v=>DB.s('nova_c',v);
const sTests=v=>DB.s('nova_tests',v);
const sRes=v=>DB.s('nova_res',v);

const SUBJ_C={Science:'#3B6FFF',Math:'#7C3AED',History:'#F59E0B',English:'#EC4899',Geography:'#10B981',Music:'#F97316',General:'#7B90B0'};

function genCode(){
  const ch='ABCDEFGHJKLMNPQRSTUVWXYZ23456789';
  let c='';for(let i=0;i<6;i++)c+=ch[Math.floor(Math.random()*ch.length)];
  return gC().some(x=>x.code===c)?genCode():c;
}
function genId(){return Date.now().toString(36)+Math.random().toString(36).slice(2,6);}

// ══ HELPERS ══
const $=id=>document.getElementById(id);
function showAuth(id){document.querySelectorAll('.auth-screen').forEach(s=>s.classList.remove('active'));$(id).classList.add('active');}
function showApp(role){
  document.querySelectorAll('.auth-screen').forEach(s=>s.classList.remove('active'));
  if(role==='teacher'){$('app').classList.add('active');$('studentApp').classList.remove('active');}
  else{$('app').classList.remove('active');$('studentApp').classList.add('active');}
}
function nav(pageId){
  document.querySelectorAll('.page').forEach(p=>p.classList.remove('active'));
  $(pageId).classList.add('active');
  document.querySelectorAll('.nav-item').forEach(n=>{n.classList.toggle('active',n.dataset.page===pageId);});
}
function pwStr(val,barEl){let s=0;if(val.length>=6)s++;if(val.length>=10)s++;if(/[A-Z]/.test(val))s++;if(/[0-9]/.test(val))s++;if(/[^A-Za-z0-9]/.test(val))s++;barEl.style.width=Math.min(s*20,100)+'%';barEl.style.background=s<=1?'#EF4444':s<=3?'#F59E0B':'#10B981';}
function msg(id,text,type='err'){const e=$(id);e.textContent=text;e.className='msg-bar '+type+' on';if(type==='ok')setTimeout(()=>e.className='msg-bar',3000);}
function clearMsg(id){$(id).className='msg-bar';}
function aMsg(id,text,type='err'){const e=$(id);e.textContent=text;e.className='a-msg '+type+' on';}

// ══ AUTH TABS ══
document.querySelectorAll('.a-tab').forEach(tab=>{
  tab.addEventListener('click',()=>{
    const card=tab.closest('.auth-card');
    const isT=card.closest('#authTeacher')!=null;
    card.querySelectorAll('.a-tab').forEach(t=>{t.classList.remove('on','t-on','s-on');});
    card.querySelectorAll('.a-form').forEach(f=>f.classList.remove('on'));
    tab.classList.add('on',isT?'t-on':'s-on');
    $(tab.dataset.f).classList.add('on');
  });
});

// ══ STATE ══
let CU=null, CR=''; // current user, current role

// ══ ROLE SELECT ══
$('goTeacher').addEventListener('click',()=>showAuth('authTeacher'));
$('goStudent').addEventListener('click',()=>showAuth('authStudent'));
$('btBack').addEventListener('click',()=>showAuth('authRole'));
$('bsBack').addEventListener('click',()=>showAuth('authRole'));

// ══ TEACHER AUTH ══
$('tr-p').addEventListener('input',()=>pwStr($('tr-p').value,$('tr-bar')));
$('tl-go').addEventListener('click',()=>{
  const e=$('tl-e').value.trim().toLowerCase(),p=$('tl-p').value;
  if(!e||!p){aMsg('tl-msg','Fill in all fields.');return;}
  const t=gT()[e];
  if(!t){aMsg('tl-msg','No account found.');return;}
  if(t.p!==p){aMsg('tl-msg','Incorrect password.');return;}
  CU=t;CR='teacher';initTeacher();
});
$('tl-p').addEventListener('keydown',e=>{if(e.key==='Enter')$('tl-go').click();});
$('tr-go').addEventListener('click',()=>{
  const fn=$('tr-fn').value.trim(),ln=$('tr-ln').value.trim(),
        e=$('tr-e').value.trim().toLowerCase(),sc=$('tr-sc').value.trim(),
        p=$('tr-p').value,p2=$('tr-p2').value;
  if(!fn||!ln||!e||!p){aMsg('tr-msg','Fill in all fields.');return;}
  if(p.length<6){aMsg('tr-msg','Password min 6 chars.');return;}
  if(p!==p2){aMsg('tr-msg','Passwords do not match.');return;}
  const ts=gT();
  if(ts[e]){aMsg('tr-msg','Account already exists.');return;}
  const u={fn,ln,e,sc,p};ts[e]=u;sT(ts);
  aMsg('tr-msg','Account created! Loading…','ok');
  setTimeout(()=>{CU=u;CR='teacher';initTeacher();},800);
});

// ══ STUDENT AUTH ══
$('sr-p').addEventListener('input',()=>pwStr($('sr-p').value,$('sr-bar')));
$('sl-go').addEventListener('click',()=>{
  const e=$('sl-e').value.trim().toLowerCase(),p=$('sl-p').value;
  if(!e||!p){aMsg('sl-msg','Fill in all fields.');return;}
  const s=gS()[e];
  if(!s){aMsg('sl-msg','No account found.');return;}
  if(s.p!==p){aMsg('sl-msg','Incorrect password.');return;}
  CU=s;CR='student';initStudent();
});
$('sl-p').addEventListener('keydown',e=>{if(e.key==='Enter')$('sl-go').click();});
$('sr-go').addEventListener('click',()=>{
  const fn=$('sr-fn').value.trim(),ln=$('sr-ln').value.trim(),
        e=$('sr-e').value.trim().toLowerCase(),id=$('sr-id').value.trim(),
        p=$('sr-p').value,p2=$('sr-p2').value;
  if(!fn||!ln||!e||!id||!p){aMsg('sr-msg','Fill in all fields.');return;}
  if(p.length<6){aMsg('sr-msg','Password min 6 chars.');return;}
  if(p!==p2){aMsg('sr-msg','Passwords do not match.');return;}
  const ss=gS();
  if(ss[e]){aMsg('sr-msg','Account already exists.');return;}
  const u={fn,ln,e,id,p,joined:[]};ss[e]=u;sS(ss);
  aMsg('sr-msg','Account created!','ok');
  setTimeout(()=>{CU=u;CR='student';initStudent();},800);
});

// ══ TEACHER INIT ══
function initTeacher(){
  $('sbAvatar').textContent=CU.fn[0].toUpperCase();
  $('sbName').textContent=CU.fn+' '+CU.ln;
  showApp('teacher');
  populateClassSelects();
  renderOverview();
  renderTestGrid();
  renderClassGrid();
  renderResults();
}
$('teacherSignout').addEventListener('click',()=>{CU=null;CR='';$('app').classList.remove('active');showAuth('authRole');});

// ══ NAV ══
document.querySelectorAll('.nav-item').forEach(btn=>{
  btn.addEventListener('click',()=>nav(btn.dataset.page));
});
$('openQuizBuilderBtn').addEventListener('click',()=>{openQuizBuilder();});
