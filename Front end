<!-- ══ TEACHER APP ══ -->
<div id="app">
  <aside class="sidebar">
    <div class="sb-logo"><div class="sb-star">✦</div><div class="sb-wm"><em>Nova</em></div></div>
    <div class="sb-user"><div class="sb-avatar" id="sbAvatar">T</div><div><div class="sb-uname" id="sbName">Teacher</div><div class="sb-urole">Educator</div></div></div>
    <nav class="sb-nav">
      <div class="sb-section">Main</div>
      <button class="nav-item active" data-page="pgOverview"><span class="ni">🏠</span>Overview</button>
      <button class="nav-item" data-page="pgTests"><span class="ni">📋</span>My Tests</button>
      <button class="nav-item" data-page="pgForms"><span class="ni">📝</span>Form Builder</button>
      <div class="sb-section">Class</div>
      <button class="nav-item" data-page="pgClasses"><span class="ni">🏫</span>Classrooms</button>
      <button class="nav-item" data-page="pgResults"><span class="ni">📊</span>Results</button>
    </nav>
    <div class="sb-bottom"><button class="signout-btn" id="teacherSignout">Sign out</button></div>
  </aside>
  <main class="main">

    <!-- OVERVIEW -->
    <div class="page active" id="pgOverview">
      <div class="page-header">
        <div><div class="page-title" id="ovTitle">Good morning! 👋</div><div class="page-sub">Here's your classroom at a glance</div></div>
        <button class="btn-primary" onclick="nav('pgTests')">＋ New Test</button>
      </div>
      <div class="grid-3">
        <div class="card stat-card"><div class="stat-icon">📋</div><div class="stat-num" id="ovTests">0</div><div class="stat-lbl">Total Tests</div></div>
        <div class="card stat-card"><div class="stat-icon">🏫</div><div class="stat-num" id="ovClasses">0</div><div class="stat-lbl">Classrooms</div></div>
        <div class="card stat-card"><div class="stat-icon">🎓</div><div class="stat-num" id="ovStudents">0</div><div class="stat-lbl">Students</div></div>
      </div>
      <div class="sec-title">Active Tests</div>
      <div id="ovActiveTests"></div>
      <div class="sec-title mt-16">Recent Results</div>
      <div id="ovRecentResults"></div>
    </div>

    <!-- MY TESTS -->
    <div class="page" id="pgTests">
      <div class="page-header">
        <div><div class="page-title">My Tests</div><div class="page-sub">Create and manage quizzes &amp; assignments</div></div>
        <div class="gap-8">
          <button class="btn-secondary btn-sm" id="openFormBuilderBtn">📝 New Form</button>
          <button class="btn-primary btn-sm" id="openQuizBuilderBtn">＋ New Quiz</button>
        </div>
      </div>
      <div class="test-grid" id="testGrid"></div>
    </div>

    <!-- QUIZ BUILDER (inside pgTests, toggleable) -->
    <div class="page" id="pgQuizBuilder">
      <div class="page-header">
        <div><div class="page-title" id="qbTitle">Quiz Builder</div><div class="page-sub">Add questions manually or bulk import</div></div>
        <div class="gap-8">
          <button class="btn-secondary btn-sm" id="cancelQB">✕ Cancel</button>
          <button class="btn-primary btn-sm" id="saveQB">💾 Save Quiz</button>
        </div>
      </div>
      <div class="builder-layout">
        <div>
          <div class="builder-meta">
