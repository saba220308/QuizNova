<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Nova — Teacher Dashboard</title>
<link href="https://fonts.googleapis.com/css2?family=Syne:wght@600;700;800&family=Inter:wght@400;500;600&display=swap" rel="stylesheet">
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0;}
:root{
  --bg:#0C1628;--card:#132035;--card2:#1C2E48;--card3:#243756;--border:#1E3250;
  --blue:#3B6FFF;--blue-d:rgba(59,111,255,.18);--blue-g:rgba(59,111,255,.3);
  --violet:#7C3AED;--green:#10B981;--green-d:rgba(16,185,129,.15);
  --amber:#F59E0B;--coral:#EF4444;--slate:#7B90B0;--slate2:#4A607E;
  --white:#EEF2FF;--r:14px;
}
html,body{min-height:100vh;background:var(--bg);font-family:'Inter',sans-serif;color:var(--white);font-size:14px;}
button{font-family:'Inter',sans-serif;cursor:pointer;}
input,textarea,select{font-family:'Inter',sans-serif;}

/* ══ AUTH SCREENS ══ */
.auth-screen{display:none;min-height:100vh;align-items:center;justify-content:center;flex-direction:column;padding:24px 16px;}
.auth-screen.active{display:flex;}
.nova-logo{display:flex;align-items:center;gap:10px;margin-bottom:28px;}
.nova-star{width:38px;height:38px;background:linear-gradient(135deg,var(--blue),var(--violet));border-radius:11px;display:flex;align-items:center;justify-content:center;font-size:1.2rem;box-shadow:0 4px 18px var(--blue-g);}
.nova-wm{font-family:'Syne',sans-serif;font-weight:800;font-size:1.65rem;letter-spacing:-.5px;}
.nova-wm em{font-style:normal;background:linear-gradient(90deg,var(--blue),var(--violet));-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;}
.auth-card{background:var(--card);border:1px solid var(--border);border-radius:var(--r);width:100%;max-width:420px;padding:28px;}
.auth-card h2{font-family:'Syne',sans-serif;font-weight:800;font-size:1.2rem;margin-bottom:4px;}
.auth-card p{color:var(--slate);font-size:.82rem;margin-bottom:22px;}
.role-grid{display:grid;grid-template-columns:1fr 1fr;gap:12px;margin-bottom:20px;}
.role-btn{background:var(--card2);border:2px solid transparent;border-radius:12px;padding:22px 14px 18px;text-align:center;color:var(--white);transition:border-color .2s,transform .15s;}
.role-btn:hover{transform:translateY(-2px);}
.role-btn.t:hover{border-color:var(--blue);}
.role-btn.s:hover{border-color:var(--green);}
.role-btn .ri{font-size:2.2rem;display:block;margin-bottom:10px;}
.role-btn .rl{font-family:'Syne',sans-serif;font-weight:700;font-size:.95rem;display:block;margin-bottom:4px;}
.role-btn .rd{font-size:.72rem;color:var(--slate);display:block;}
.a-tabs{display:grid;grid-template-columns:1fr 1fr;background:var(--card2);border-radius:10px;padding:3px;margin-bottom:18px;gap:3px;}
.a-tab{background:none;border:none;border-radius:8px;padding:9px;font-family:'Syne',sans-serif;font-weight:700;font-size:.82rem;color:var(--slate);transition:background .18s,color .18s;}
.a-tab.on{color:#fff;}
.a-tab.t-on{background:var(--blue);}
.a-tab.s-on{background:var(--green);}
.a-form{display:none;}
.a-form.on{display:block;}
.f{margin-bottom:12px;}
.f label{display:block;font-size:.72rem;font-weight:600;color:var(--slate);letter-spacing:.05em;text-transform:uppercase;margin-bottom:5px;}
.f input{width:100%;background:var(--card2);border:1.5px solid transparent;border-radius:9px;padding:11px 14px;color:var(--white);font-size:.9rem;outline:none;transition:border-color .18s;}
.f input::placeholder{color:var(--slate2);}
.f input:focus{border-color:var(--blue);}
.f-row{display:grid;grid-template-columns:1fr 1fr;gap:10px;}
.pw-bar-wrap{height:3px;border-radius:2px;margin-top:5px;background:var(--bg);overflow:hidden;}
.pw-bar{height:100%;border-radius:2px;width:0%;transition:width .3s,background .3s;}
.sub-btn{width:100%;border:none;border-radius:10px;padding:13px;font-family:'Syne',sans-serif;font-weight:700;font-size:.9rem;margin-top:5px;transition:transform .15s,opacity .2s;}
.sub-btn.t{background:linear-gradient(135deg,var(--blue),var(--violet));color:#fff;box-shadow:0 4px 18px var(--blue-g);}
.sub-btn.s{background:var(--green);color:#fff;box-shadow:0 4px 16px rgba(16,185,129,.3);}
.sub-btn:hover{transform:translateY(-1px);}
.a-msg{border-radius:9px;padding:9px 13px;font-size:.8rem;font-weight:500;margin-top:10px;display:none;gap:7px;}
.a-msg.on{display:flex;}
.a-msg.err{background:rgba(239,68,68,.1);border:1px solid rgba(239,68,68,.3);color:var(--coral);}
.a-msg.ok{background:var(--green-d);border:1px solid rgba(16,185,129,.3);color:var(--green);}
.back-link{background:none;border:none;color:var(--slate);font-size:.8rem;margin-bottom:18px;display:flex;align-items:center;gap:5px;padding:0;transition:color .15s;}
.back-link:hover{color:var(--white);}

/* ══ APP SHELL ══ */
#app{display:none;min-height:100vh;flex-direction:row;}
#app.active{display:flex;}

/* SIDEBAR */
.sidebar{width:220px;min-height:100vh;background:var(--card);border-right:1px solid var(--border);display:flex;flex-direction:column;flex-shrink:0;position:sticky;top:0;height:100vh;overflow-y:auto;}
.sb-logo{display:flex;align-items:center;gap:9px;padding:20px 18px 16px;}
.sb-star{width:30px;height:30px;background:linear-gradient(135deg,var(--blue),var(--violet));border-radius:8px;display:flex;align-items:center;justify-content:center;font-size:.95rem;}
.sb-wm{font-family:'Syne',sans-serif;font-weight:800;font-size:1.15rem;}
.sb-wm em{font-style:normal;background:linear-gradient(90deg,var(--blue),var(--violet));-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;}
.sb-user{margin:0 12px 16px;background:var(--card2);border-radius:10px;padding:11px 12px;display:flex;align-items:center;gap:9px;}
.sb-avatar{width:30px;height:30px;border-radius:50%;background:linear-gradient(135deg,var(--blue),var(--violet));display:flex;align-items:center;justify-content:center;font-family:'Syne',sans-serif;font-weight:800;font-size:.8rem;flex-shrink:0;}
.sb-uname{font-weight:600;font-size:.82rem;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;}
.sb-urole{font-size:.7rem;color:var(--slate);}
.sb-nav{flex:1;padding:0 10px;}
.sb-section{font-size:.65rem;font-weight:700;letter-spacing:.08em;text-transform:uppercase;color:var(--slate2);padding:12px 8px 6px;}
.nav-item{display:flex;align-items:center;gap:9px;padding:9px 10px;border-radius:9px;color:var(--slate);font-weight:500;font-size:.84rem;border:none;background:none;width:100%;text-align:left;transition:background .15s,color .15s;margin-bottom:2px;}
.nav-item .ni{font-size:1rem;width:20px;text-align:center;flex-shrink:0;}
.nav-item:hover{background:var(--card2);color:var(--white);}
.nav-item.active{background:var(--blue-d);color:var(--blue);}
.nav-item .nbadge{margin-left:auto;background:var(--blue);color:#fff;border-radius:100px;font-size:.62rem;font-weight:700;padding:1px 7px;}
.sb-bottom{padding:14px 12px;}
.signout-btn{width:100%;background:none;border:1px solid var(--border);border-radius:9px;padding:9px;color:var(--slate);font-size:.8rem;font-family:'Inter',sans-serif;transition:color .15s,border-color .15s;}
.signout-btn:hover{color:var(--coral);border-color:rgba(239,68,68,.4);}

/* MAIN CONTENT */
.main{flex:1;overflow-y:auto;min-height:100vh;}
.page{display:none;padding:28px;}
.page.active{display:block;}
.page-header{display:flex;align-items:flex-start;justify-content:space-between;margin-bottom:24px;gap:16px;flex-wrap:wrap;}
.page-title{font-family:'Syne',sans-serif;font-weight:800;font-size:1.35rem;}
.page-sub{color:var(--slate);font-size:.82rem;margin-top:3px;}
.btn-primary{background:linear-gradient(135deg,var(--blue),var(--violet));color:#fff;border:none;border-radius:10px;padding:10px 18px;font-family:'Syne',sans-serif;font-weight:700;font-size:.83rem;box-shadow:0 4px 16px var(--blue-g);transition:transform .15s,opacity .15s;display:inline-flex;align-items:center;gap:7px;}
.btn-primary:hover{transform:translateY(-1px);}
.btn-secondary{background:var(--card2);border:1px solid var(--border);color:var(--white);border-radius:10px;padding:10px 16px;font-family:'Syne',sans-serif;font-weight:700;font-size:.83rem;transition:background .15s;display:inline-flex;align-items:center;gap:7px;}
.btn-secondary:hover{background:var(--card3);}
.btn-sm{padding:7px 13px;font-size:.78rem;}
.btn-danger{background:rgba(239,68,68,.1);border:1px solid rgba(239,68,68,.3);color:var(--coral);border-radius:8px;padding:7px 12px;font-size:.78rem;font-weight:600;transition:background .15s;}
.btn-danger:hover{background:rgba(239,68,68,.2);}

/* CARDS */
.card{background:var(--card);border:1px solid var(--border);border-radius:var(--r);}
.grid-3{display:grid;grid-template-columns:repeat(3,1fr);gap:14px;margin-bottom:24px;}
.grid-2{display:grid;grid-template-columns:repeat(2,1fr);gap:14px;}
.stat-card{padding:18px 20px;}
.stat-icon{font-size:1.4rem;margin-bottom:10px;}
.stat-num{font-family:'Syne',sans-serif;font-weight:800;font-size:1.9rem;color:var(--blue);line-height:1;}
.stat-lbl{color:var(--slate);font-size:.75rem;margin-top:4px;}
.stat-change{font-size:.72rem;margin-top:6px;}
.stat-change.up{color:var(--green);}

/* SECTION TITLE */
.sec-title{font-family:'Syne',sans-serif;font-weight:700;font-size:.8rem;letter-spacing:.06em;text-transform:uppercase;color:var(--slate);margin-bottom:12px;}

/* TEST CARDS */
.test-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(280px,1fr));gap:14px;margin-bottom:24px;}
.test-card{padding:18px;position:relative;overflow:hidden;transition:border-color .2s;}
.test-card:hover{border-color:var(--slate2);}
.test-accent{position:absolute;top:0;left:0;right:0;height:3px;}
.test-card-head{display:flex;align-items:flex-start;justify-content:space-between;margin-bottom:10px;gap:8px;}
.test-title{font-family:'Syne',sans-serif;font-weight:700;font-size:.95rem;line-height:1.3;}
.test-type-badge{font-size:.62rem;font-weight:700;letter-spacing:.07em;text-transform:uppercase;padding:3px 9px;border-radius:100px;white-space:nowrap;flex-shrink:0;}
.test-type-badge.quiz{background:var(--blue-d);color:var(--blue);}
.test-type-badge.form{background:rgba(124,58,237,.15);color:#A78BFA;}
.test-meta{color:var(--slate);font-size:.75rem;margin-bottom:12px;display:flex;align-items:center;gap:12px;flex-wrap:wrap;}
.test-meta span{display:flex;align-items:center;gap:4px;}
.test-footer{display:flex;align-items:center;justify-content:space-between;gap:8px;}
.toggle-wrap{display:flex;align-items:center;gap:7px;}
.toggle{position:relative;width:34px;height:18px;flex-shrink:0;}
.toggle input{opacity:0;width:0;height:0;position:absolute;}
.toggle-track{position:absolute;inset:0;background:var(--card3);border-radius:100px;transition:background .2s;cursor:pointer;}
.toggle input:checked+.toggle-track{background:var(--green);}
.toggle-thumb{position:absolute;top:3px;left:3px;width:12px;height:12px;background:#fff;border-radius:50%;transition:transform .2s;pointer-events:none;}
.toggle input:checked~.toggle-thumb{transform:translateX(16px);}
.toggle-lbl{font-size:.75rem;color:var(--slate);}
.test-actions{display:flex;gap:6px;}
.icon-btn{background:var(--card2);border:1px solid var(--border);border-radius:7px;padding:6px 9px;color:var(--slate);font-size:.82rem;transition:color .15s,background .15s;}
.icon-btn:hover{background:var(--card3);color:var(--white);}
.icon-btn.del:hover{background:rgba(239,68,68,.1);color:var(--coral);border-color:rgba(239,68,68,.3);}

/* ══ QUIZ BUILDER ══ */
.builder-layout{display:grid;grid-template-columns:1fr 340px;gap:18px;align-items:start;}
.builder-meta{background:var(--card);border:1px solid var(--border);border-radius:var(--r);padding:20px;margin-bottom:18px;}
.builder-meta h3{font-family:'Syne',sans-serif;font-weight:700;font-size:.9rem;margin-bottom:14px;}
.b-input{width:100%;background:var(--card2);border:1.5px solid transparent;border-radius:9px;padding:11px 14px;color:var(--white);font-size:.9rem;outline:none;transition:border-color .18s;margin-bottom:10px;}
.b-input::placeholder{color:var(--slate2);}
.b-input:focus{border-color:var(--blue);}
.b-select{width:100%;background:var(--card2);border:1.5px solid transparent;border-radius:9px;padding:11px 14px;color:var(--white);font-size:.9rem;outline:none;transition:border-color .18s;appearance:none;margin-bottom:10px;}
.b-select:focus{border-color:var(--blue);}
.b-select option{background:var(--card);}
.b-label{font-size:.72rem;font-weight:600;color:var(--slate);letter-spacing:.05em;text-transform:uppercase;margin-bottom:5px;display:block;}
.b-field{margin-bottom:12px;}
.q-list{display:flex;flex-direction:column;gap:10px;margin-bottom:14px;}
.q-item{background:var(--card);border:1px solid var(--border);border-radius:12px;padding:16px;position:relative;}
.q-item-head{display:flex;align-items:center;justify-content:space-between;margin-bottom:10px;gap:8px;}
.q-num{font-family:'Syne',sans-serif;font-weight:700;font-size:.75rem;color:var(--blue);background:var(--blue-d);padding:3px 9px;border-radius:100px;}
.q-type-lbl{font-size:.7rem;color:var(--slate);margin-left:auto;}
.q-text{font-weight:500;font-size:.88rem;margin-bottom:10px;line-height:1.45;}
.q-options{display:flex;flex-direction:column;gap:5px;}
.q-opt{display:flex;align-items:center;gap:8px;padding:6px 10px;border-radius:7px;font-size:.83rem;}
.q-opt.correct{background:rgba(16,185,129,.1);border:1px solid rgba(16,185,129,.3);color:var(--green);}
.q-opt.wrong{background:var(--card2);color:var(--slate);}
.q-opt .oi{font-size:.75rem;width:18px;height:18px;border-radius:50%;border:1.5px solid currentColor;display:flex;align-items:center;justify-content:center;flex-shrink:0;}
.q-item-del{position:absolute;top:10px;right:10px;background:none;border:none;color:var(--slate2);font-size:.85rem;padding:4px 6px;border-radius:6px;transition:color .15s,background .15s;}
.q-item-del:hover{color:var(--coral);background:rgba(239,68,68,.1);}
.empty-qs{text-align:center;padding:36px 16px;color:var(--slate);background:var(--card2);border-radius:12px;border:1px dashed var(--border);}
.empty-qs span{font-size:2rem;display:block;margin-bottom:10px;}

/* Add question panel */
.add-q-panel{background:var(--card);border:1px solid var(--border);border-radius:var(--r);padding:20px;position:sticky;top:20px;}
.add-q-panel h3{font-family:'Syne',sans-serif;font-weight:700;font-size:.9rem;margin-bottom:14px;}
.q-type-tabs{display:flex;gap:5px;margin-bottom:14px;flex-wrap:wrap;}
.q-type-tab{background:var(--card2);border:1px solid var(--border);border-radius:7px;padding:5px 11px;font-size:.76rem;font-weight:600;color:var(--slate);transition:background .15s,color .15s,border-color .15s;}
.q-type-tab.on{background:var(--blue-d);border-color:var(--blue);color:var(--blue);}
.option-list{display:flex;flex-direction:column;gap:6px;margin-bottom:10px;}
.option-row{display:flex;align-items:center;gap:7px;}
.opt-radio{width:16px;height:16px;accent-color:var(--green);flex-shrink:0;cursor:pointer;}
.opt-input{flex:1;background:var(--card2);border:1.5px solid transparent;border-radius:8px;padding:9px 12px;color:var(--white);font-size:.85rem;outline:none;transition:border-color .18s;}
.opt-input:focus{border-color:var(--blue);}
.opt-input::placeholder{color:var(--slate2);}
.opt-del{background:none;border:none;color:var(--slate2);font-size:.8rem;padding:4px;transition:color .15s;}
.opt-del:hover{color:var(--coral);}
.add-opt-btn{background:none;border:1px dashed var(--border);border-radius:8px;padding:8px 12px;color:var(--slate);font-size:.8rem;width:100%;transition:border-color .15s,color .15s;margin-bottom:12px;}
.add-opt-btn:hover{border-color:var(--blue);color:var(--blue);}
.correct-hint{font-size:.72rem;color:var(--slate);margin-bottom:10px;}

/* Bulk import */
.bulk-box{background:var(--card2);border:1px dashed var(--border);border-radius:10px;padding:14px;margin-bottom:12px;}
.bulk-box textarea{width:100%;background:transparent;border:none;color:var(--white);font-size:.8rem;font-family:'Inter',sans-serif;resize:vertical;min-height:100px;outline:none;line-height:1.6;}
.bulk-box textarea::placeholder{color:var(--slate2);}
.bulk-hint{font-size:.72rem;color:var(--slate);margin-top:6px;line-height:1.5;}

/* ══ FORM BUILDER ══ */
.form-canvas{display:flex;flex-direction:column;gap:10px;margin-bottom:14px;}
.form-field-card{background:var(--card);border:1.5px solid var(--border);border-radius:12px;padding:16px;position:relative;transition:border-color .2s;}
.form-field-card:hover{border-color:var(--slate2);}
.form-field-card.dragging{opacity:.5;border-color:var(--blue);}
.ffc-head{display:flex;align-items:center;gap:10px;margin-bottom:10px;}
.drag-handle{color:var(--slate2);font-size:.9rem;cursor:grab;}
.ffc-type-badge{font-size:.65rem;font-weight:700;letter-spacing:.07em;text-transform:uppercase;padding:2px 8px;border-radius:100px;background:var(--card2);color:var(--slate);}
.ffc-del{position:absolute;top:12px;right:12px;background:none;border:none;color:var(--slate2);font-size:.82rem;padding:4px 6px;border-radius:6px;transition:color .15s,background .15s;}
.ffc-del:hover{color:var(--coral);background:rgba(239,68,68,.1);}
.ffc-required{display:flex;align-items:center;gap:6px;font-size:.75rem;color:var(--slate);margin-top:8px;}
.ffc-required input{accent-color:var(--blue);}
.form-preview-field{margin-top:10px;}
.form-preview-field label{display:block;font-size:.82rem;font-weight:500;margin-bottom:5px;}
.form-preview-field .req-star{color:var(--coral);}
.preview-input{width:100%;background:var(--card2);border:1.5px solid var(--border);border-radius:8px;padding:9px 12px;color:var(--white);font-size:.82rem;outline:none;cursor:default;}
.preview-textarea{width:100%;background:var(--card2);border:1.5px solid var(--border);border-radius:8px;padding:9px 12px;color:var(--white);font-size:.82rem;outline:none;cursor:default;resize:none;min-height:64px;}
.preview-option{display:flex;align-items:center;gap:8px;padding:6px 0;font-size:.83rem;color:var(--slate);}
.preview-option input{accent-color:var(--blue);}
.add-field-bar{display:flex;gap:8px;flex-wrap:wrap;margin-bottom:18px;}
.add-field-btn{background:var(--card);border:1px solid var(--border);border-radius:9px;padding:8px 13px;color:var(--slate);font-size:.78rem;font-weight:500;transition:background .15s,color .15s,border-color .15s;display:flex;align-items:center;gap:6px;}
.add-field-btn:hover{background:var(--card2);color:var(--white);border-color:var(--slate2);}

/* ══ CLASSROOMS ══ */
.class-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(260px,1fr));gap:14px;margin-bottom:20px;}
.class-card-v2{padding:18px;position:relative;overflow:hidden;}
.cc-accent{position:absolute;left:0;top:0;bottom:0;width:4px;}
.cc-body{padding-left:14px;}
.cc-name{font-family:'Syne',sans-serif;font-weight:700;font-size:.95rem;margin-bottom:4px;}
.cc-sub{font-size:.75rem;color:var(--slate);margin-bottom:12px;}
.code-display{background:var(--card2);border-radius:10px;padding:12px 14px;display:flex;align-items:center;justify-content:space-between;gap:10px;margin-bottom:10px;}
.code-lbl{font-size:.65rem;font-weight:700;letter-spacing:.07em;text-transform:uppercase;color:var(--slate);margin-bottom:3px;}
.code-val{font-family:'Syne',sans-serif;font-weight:800;font-size:1.5rem;letter-spacing:.2em;color:var(--blue);text-shadow:0 0 18px var(--blue-g);}
.copy-btn{background:var(--blue-d);border:1px solid rgba(59,111,255,.3);border-radius:8px;padding:7px 12px;color:var(--blue);font-family:'Syne',sans-serif;font-weight:700;font-size:.75rem;transition:background .15s,color .15s;display:flex;align-items:center;gap:5px;flex-shrink:0;}
.copy-btn:hover{background:var(--blue);color:#fff;}
.copy-btn.copied{background:var(--green-d);border-color:rgba(16,185,129,.3);color:var(--green);}
.cc-footer{display:flex;align-items:center;justify-content:space-between;}
.cc-students{font-size:.75rem;color:var(--slate);}

/* Create classroom form */
.create-class-box{background:var(--card);border:1px solid var(--border);border-radius:var(--r);padding:20px;margin-bottom:20px;}
.create-class-box h3{font-family:'Syne',sans-serif;font-weight:700;font-size:.88rem;margin-bottom:14px;display:flex;align-items:center;gap:7px;}
.chip-wrap{display:flex;flex-wrap:wrap;gap:6px;margin-bottom:12px;}
.chip{background:var(--card2);border:1.5px solid var(--border);border-radius:7px;padding:5px 11px;font-size:.75rem;font-weight:500;color:var(--slate);transition:all .15s;}
.chip:hover{border-color:var(--blue);color:var(--blue);}
.chip.on{border-color:var(--blue);background:var(--blue-d);color:var(--blue);}

/* ══ RESULTS ══ */
.results-filter{display:flex;gap:8px;margin-bottom:18px;flex-wrap:wrap;}
.filter-btn{background:var(--card2);border:1px solid var(--border);border-radius:8px;padding:7px 14px;font-size:.78rem;font-weight:500;color:var(--slate);transition:all .15s;}
.filter-btn.on{background:var(--blue-d);border-color:var(--blue);color:var(--blue);}
.results-table{background:var(--card);border:1px solid var(--border);border-radius:var(--r);overflow:hidden;margin-bottom:20px;}
.rt-head{display:grid;grid-template-columns:2fr 1.5fr 1fr 1fr 80px;gap:0;background:var(--card2);border-bottom:1px solid var(--border);}
.rt-cell{padding:11px 16px;font-size:.73rem;font-weight:700;letter-spacing:.05em;text-transform:uppercase;color:var(--slate);}
.rt-row{display:grid;grid-template-columns:2fr 1.5fr 1fr 1fr 80px;border-bottom:1px solid var(--border);transition:background .15s;}
.rt-row:last-child{border-bottom:none;}
.rt-row:hover{background:var(--card2);}
.rt-row .rt-cell{font-size:.83rem;font-weight:400;color:var(--white);text-transform:none;letter-spacing:0;}
.score-bar-wrap{display:flex;align-items:center;gap:8px;}
.score-bar{height:5px;border-radius:3px;background:var(--card2);flex:1;overflow:hidden;}
.score-bar-fill{height:100%;border-radius:3px;background:linear-gradient(90deg,var(--blue),var(--violet));}
.score-pct{font-family:'Syne',sans-serif;font-weight:700;font-size:.78rem;color:var(--blue);white-space:nowrap;}
.status-pill{font-size:.68rem;font-weight:700;padding:3px 9px;border-radius:100px;}
.status-pill.done{background:rgba(16,185,129,.15);color:var(--green);}
.status-pill.pend{background:rgba(123,144,176,.1);color:var(--slate);}

/* ══ STUDENT SCREENS ══ */
.student-app{display:none;min-height:100vh;flex-direction:column;align-items:center;padding:32px 16px 48px;}
.student-app.active{display:flex;}
.s-topbar{width:100%;max-width:640px;display:flex;align-items:center;justify-content:space-between;margin-bottom:28px;}
.s-user-pill{display:flex;align-items:center;gap:8px;background:var(--green-d);border:1px solid rgba(16,185,129,.25);border-radius:100px;padding:5px 13px 5px 6px;}
.s-avatar{width:26px;height:26px;border-radius:50%;background:var(--green);display:flex;align-items:center;justify-content:center;font-family:'Syne',sans-serif;font-weight:800;font-size:.75rem;}
.s-uname{font-size:.8rem;font-weight:600;color:var(--green);}
.s-signout{background:none;border:none;color:var(--slate);font-size:.77rem;}
.s-signout:hover{color:var(--coral);}
.s-card{background:var(--card);border:1px solid var(--border);border-radius:var(--r);width:100%;max-width:640px;padding:28px;}

/* Join code */
.join-code-wrap{background:var(--card2);border-radius:12px;padding:20px;margin-bottom:16px;}
.join-code-wrap h3{font-family:'Syne',sans-serif;font-weight:700;font-size:.9rem;margin-bottom:5px;}
.join-code-wrap p{color:var(--slate);font-size:.78rem;margin-bottom:14px;}
.code-row{display:flex;gap:9px;}
.code-inp{flex:1;background:var(--card);border:2px solid var(--border);border-radius:10px;padding:13px 16px;color:var(--white);font-family:'Syne',sans-serif;font-weight:800;font-size:1.35rem;letter-spacing:.18em;text-transform:uppercase;text-align:center;outline:none;transition:border-color .18s;}
.code-inp::placeholder{font-size:.9rem;font-weight:400;letter-spacing:.03em;color:var(--slate2);}
.code-inp:focus{border-color:var(--blue);}
.lookup-btn{background:linear-gradient(135deg,var(--blue),var(--violet));color:#fff;border:none;border-radius:10px;padding:13px 18px;font-family:'Syne',sans-serif;font-weight:700;font-size:.85rem;box-shadow:0 4px 14px var(--blue-g);transition:transform .15s;white-space:nowrap;}
.lookup-btn:hover{transform:translateY(-1px);}
.join-msg{border-radius:9px;padding:9px 13px;font-size:.8rem;font-weight:500;margin-top:10px;display:none;gap:7px;}
.join-msg.on{display:flex;}
.join-msg.err{background:rgba(239,68,68,.1);border:1px solid rgba(239,68,68,.3);color:var(--coral);}
.join-msg.ok{background:var(--green-d);border:1px solid rgba(16,185,129,.3);color:var(--green);}
.found-card{background:var(--card2);border:2px solid var(--blue);border-radius:12px;padding:16px;display:none;margin-bottom:12px;position:relative;overflow:hidden;}
.found-card.on{display:block;}
.found-accent{position:absolute;left:0;top:0;bottom:0;width:4px;}
.found-body{padding-left:14px;}
.found-name{font-family:'Syne',sans-serif;font-weight:700;font-size:1rem;margin-bottom:4px;}
.found-detail{font-size:.78rem;color:var(--slate);margin-bottom:2px;}
.start-btn{width:100%;background:var(--green);color:#fff;border:none;border-radius:11px;padding:13px;font-family:'Syne',sans-serif;font-weight:700;font-size:.9rem;box-shadow:0 4px 18px rgba(16,185,129,.3);transition:transform .15s;display:none;margin-bottom:12px;}
.start-btn.on{display:block;}
.start-btn:hover{transform:translateY(-1px);}

/* Quiz play */
.progress-track{width:100%;height:4px;background:var(--card2);border-radius:2px;margin-bottom:20px;overflow:hidden;}
.progress-fill{height:100%;background:linear-gradient(90deg,var(--blue),var(--violet));border-radius:2px;transition:width .5s cubic-bezier(.4,0,.2,1);}
.q-topbar{display:flex;align-items:center;justify-content:space-between;margin-bottom:15px;}
.q-class-pill{display:flex;align-items:center;gap:6px;background:var(--blue-d);border:1px solid rgba(59,111,255,.25);border-radius:100px;padding:4px 11px 4px 7px;}
.q-class-pill-dot{width:6px;height:6px;border-radius:50%;background:var(--blue);}
.q-class-pill-name{font-size:.74rem;font-weight:600;color:var(--blue);}
.q-exit-btn{background:none;border:none;color:var(--slate2);font-size:.74rem;}
.q-exit-btn:hover{color:var(--coral);}
.q-meta{display:flex;align-items:center;justify-content:space-between;margin-bottom:14px;}
.arc-wrap{position:relative;width:52px;height:52px;}
.arc-wrap svg{transform:rotate(-90deg);overflow:visible;}
.arc-bg{fill:none;stroke:var(--card2);stroke-width:4;}
.arc-fill{fill:none;stroke:url(#ag);stroke-width:4;stroke-linecap:round;stroke-dasharray:138.23;stroke-dashoffset:138.23;transition:stroke-dashoffset .6s cubic-bezier(.4,0,.2,1);}
.arc-label{position:absolute;inset:0;display:flex;align-items:center;justify-content:center;font-family:'Syne',sans-serif;font-weight:700;font-size:.85rem;}
.cat-tag{font-size:.68rem;font-weight:700;letter-spacing:.07em;text-transform:uppercase;color:var(--blue);background:var(--blue-d);border:1px solid rgba(59,111,255,.22);padding:4px 11px;border-radius:100px;}
.timer-strip{display:flex;align-items:center;gap:9px;margin-bottom:14px;}
.timer-track{flex:1;height:3px;background:var(--card2);border-radius:2px;overflow:hidden;}
.timer-fill{height:100%;border-radius:2px;transition:width 1s linear,background .5s;}
.timer-num{font-family:'Syne',sans-serif;font-weight:700;font-size:.8rem;color:var(--slate);width:22px;text-align:right;}
.quiz-q{font-family:'Syne',sans-serif;font-weight:700;font-size:clamp(1rem,3vw,1.25rem);line-height:1.5;margin-bottom:18px;}
.ans-grid{display:grid;grid-template-columns:1fr 1fr;gap:9px;margin-bottom:18px;}
.ans-btn{background:var(--card2);border:1.5px solid transparent;border-radius:11px;padding:13px 14px;color:var(--white);font-size:.85rem;font-weight:500;line-height:1.4;text-align:left;transition:border-color .18s,transform .12s;position:relative;overflow:hidden;}
.ans-btn::before{content:'';position:absolute;inset:0;background:var(--blue-d);opacity:0;transition:opacity .18s;}
.ans-btn:hover:not(:disabled)::before{opacity:1;}
.ans-btn:hover:not(:disabled){border-color:var(--blue);transform:translateY(-1px);}
.ans-btn:disabled{cursor:default;}
.ans-btn.correct{background:rgba(245,158,11,.1);border-color:var(--amber);color:var(--amber);}
.ans-btn.wrong{background:rgba(239,68,68,.08);border-color:var(--coral);color:var(--coral);}
.ans-btn.reveal{background:rgba(245,158,11,.05);border-color:rgba(245,158,11,.2);color:rgba(238,242,255,.4);}
.ans-lbl{display:inline-flex;align-items:center;justify-content:center;width:20px;height:20px;border-radius:5px;background:rgba(123,144,176,.18);font-family:'Syne',sans-serif;font-size:.7rem;font-weight:700;margin-right:8px;flex-shrink:0;vertical-align:middle;}
.ans-btn.correct .ans-lbl{background:var(--amber);color:var(--bg);}
.ans-btn.wrong .ans-lbl{background:var(--coral);color:#fff;}
.q-fb{min-height:34px;border-radius:9px;padding:8px 13px;font-size:.82rem;font-weight:500;display:flex;align-items:center;gap:8px;opacity:0;transform:translateY(4px);transition:opacity .25s,transform .25s;margin-bottom:14px;}
.q-fb.on{opacity:1;transform:none;}
.q-fb.c{background:rgba(245,158,11,.1);color:var(--amber);border:1px solid rgba(245,158,11,.3);}
.q-fb.w{background:rgba(239,68,68,.07);color:var(--coral);border:1px solid rgba(239,68,68,.3);}
.next-q-btn{width:100%;background:linear-gradient(135deg,var(--blue),var(--violet));color:#fff;font-family:'Syne',sans-serif;font-weight:700;font-size:.9rem;border:none;border-radius:11px;padding:13px;opacity:0;pointer-events:none;transition:opacity .25s,transform .15s;box-shadow:0 4px 18px var(--blue-g);}
.next-q-btn.on{opacity:1;pointer-events:auto;}
.next-q-btn:hover{transform:translateY(-1px);}

/* Form play */
.form-play-field{margin-bottom:18px;}
.form-play-field label{display:block;font-size:.88rem;font-weight:500;margin-bottom:8px;line-height:1.4;}
.form-play-field .req{color:var(--coral);}
.form-play-input{width:100%;background:var(--card2);border:1.5px solid var(--border);border-radius:9px;padding:11px 14px;color:var(--white);font-size:.88rem;outline:none;transition:border-color .18s;}
.form-play-input:focus{border-color:var(--blue);}
.form-play-textarea{width:100%;background:var(--card2);border:1.5px solid var(--border);border-radius:9px;padding:11px 14px;color:var(--white);font-size:.88rem;outline:none;resize:vertical;min-height:80px;transition:border-color .18s;}
.form-play-textarea:focus{border-color:var(--blue);}
.form-play-select{width:100%;background:var(--card2);border:1.5px solid var(--border);border-radius:9px;padding:11px 14px;color:var(--white);font-size:.88rem;outline:none;appearance:none;}
.form-play-option{display:flex;align-items:center;gap:9px;padding:8px 0;font-size:.85rem;}
.form-play-option input{accent-color:var(--blue);width:15px;height:15px;}
.submit-form-btn{width:100%;background:var(--green);color:#fff;border:none;border-radius:11px;padding:13px;font-family:'Syne',sans-serif;font-weight:700;font-size:.9rem;box-shadow:0 4px 16px rgba(16,185,129,.3);transition:transform .15s;}
.submit-form-btn:hover{transform:translateY(-1px);}

/* Score screen */
.score-screen{text-align:center;padding:8px 0;}
.sc-emoji{font-size:3rem;margin-bottom:12px;}
.sc-headline{font-family:'Syne',sans-serif;font-weight:800;font-size:clamp(1.4rem,4vw,1.9rem);margin-bottom:6px;}
.sc-sub{color:var(--slate);font-size:.88rem;margin-bottom:5px;}
.sc-class{font-size:.75rem;color:var(--blue);margin-bottom:22px;}
.sc-big{font-family:'Syne',sans-serif;font-weight:800;font-size:clamp(2.5rem,10vw,4rem);background:linear-gradient(135deg,var(--blue),var(--violet));-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;line-height:1;margin-bottom:4px;}
.sc-den{color:var(--slate);font-size:.9rem;margin-bottom:26px;}
.sc-acts{display:flex;gap:10px;justify-content:center;}
.sc-home{background:var(--card2);border:1px solid var(--border);color:var(--slate);font-family:'Syne',sans-serif;font-weight:700;font-size:.88rem;border-radius:10px;padding:11px 24px;}
.sc-home:hover{color:var(--white);}
.sc-again{background:transparent;border:1.5px solid var(--blue);color:var(--blue);font-family:'Syne',sans-serif;font-weight:700;font-size:.88rem;border-radius:10px;padding:11px 24px;transition:background .18s,color .18s;}
.sc-again:hover{background:var(--blue);color:#fff;}

/* Form submitted */
.form-done{text-align:center;padding:28px 0;}
.form-done-icon{font-size:3rem;margin-bottom:14px;}
.form-done h2{font-family:'Syne',sans-serif;font-weight:800;font-size:1.4rem;margin-bottom:8px;}
.form-done p{color:var(--slate);font-size:.88rem;margin-bottom:24px;}

/* Utils */
.gap-8{display:flex;gap:8px;align-items:center;flex-wrap:wrap;}
.mt-16{margin-top:16px;}
.divider{height:1px;background:var(--border);margin:18px 0;}
.msg-bar{border-radius:9px;padding:9px 13px;font-size:.8rem;font-weight:500;display:none;gap:7px;align-items:center;margin-top:10px;}
.msg-bar.on{display:flex;}
.msg-bar.err{background:rgba(239,68,68,.1);border:1px solid rgba(239,68,68,.3);color:var(--coral);}
.msg-bar.ok{background:var(--green-d);border:1px solid rgba(16,185,129,.3);color:var(--green);}
@media(max-width:900px){.builder-layout{grid-template-columns:1fr;}.sidebar{width:180px;}.rt-head,.rt-row{grid-template-columns:2fr 1fr 1fr 70px;}.rt-head .rt-cell:nth-child(2),.rt-row .rt-cell:nth-child(2){display:none;}}
@media(max-width:640px){.sidebar{display:none;}.main{width:100%;}.grid-3{grid-template-columns:1fr 1fr;}.ans-grid{grid-template-columns:1fr;}.page{padding:18px;}}
</style>
</head>
<body>

