const FIELD_TYPES={short:{label:'Short Text',icon:'✏️'},para:{label:'Paragraph',icon:'📄'},mcq:{label:'Multiple Choice',icon:'⭕'},check:{label:'Checkboxes',icon:'☑️'},drop:{label:'Dropdown',icon:'▾'},scale:{label:'Rating Scale',icon:'⭐'}};
document.querySelectorAll('.add-field-btn').forEach(btn=>{
  btn.addEventListener('click',()=>{
    const ft=btn.dataset.ft;
    const field={id:genId(),type:ft,label:'',required:false,options:['Option 1','Option 2','Option 3']};
    fbFields.push(field);renderFormCanvas();
  });
});

function renderFormCanvas(){
  $('formEmpty').style.display=fbFields.length?'none':'block';
  const canvas=$('formCanvas');
  canvas.innerHTML=fbFields.map((f,i)=>{
    const ft=FIELD_TYPES[f.type]||{label:f.type,icon:'❓'};
    let previewHTML='';
    if(f.type==='short') previewHTML=`<input class="preview-input" disabled placeholder="Short answer text">`;
    else if(f.type==='para') previewHTML=`<textarea class="preview-textarea" disabled placeholder="Long answer text"></textarea>`;
    else if(f.type==='scale') previewHTML=`<div style="display:flex;gap:8px;margin-top:4px;">${[1,2,3,4,5].map(n=>`<div style="width:34px;height:34px;border-radius:8px;background:var(--card2);border:1.5px solid var(--border);display:flex;align-items:center;justify-content:center;font-size:.85rem;color:var(--slate);">${n}</div>`).join('')}</div>`;
    else if(['mcq','check','drop'].includes(f.type)){
      if(f.type==='drop') previewHTML=`<select class="preview-input" disabled><option>Select an option</option>${f.options.map(o=>`<option>${o}</option>`).join('')}</select>`;
      else previewHTML=f.options.map(o=>`<div class="preview-option"><input type="${f.type==='check'?'checkbox':'radio'}" disabled name="prev_${f.id}"><span>${o}</span></div>`).join('');
    }
    const hasOpts=['mcq','check','drop'].includes(f.type);
    return `
      <div class="form-field-card" data-fi="${i}">
        <button class="ffc-del" data-fi="${i}">✕</button>
        <div class="ffc-head">
          <span class="drag-handle">⠿</span>
          <span class="ffc-type-badge">${ft.icon} ${ft.label}</span>
        </div>
        <input class="b-input" value="${f.label}" placeholder="Question / label…" data-fi="${i}" style="margin-bottom:8px;" oninput="fbFields[${i}].label=this.value">
        ${hasOpts?`<div style="margin-bottom:8px;">
          <label class="b-label">Options</label>
          <div id="fopts_${i}">${f.options.map((o,oi)=>`<div class="option-row" style="margin-bottom:5px;"><input class="opt-input" value="${o}" data-fi="${i}" data-oi="${oi}" oninput="fbFields[${i}].options[${oi}]=this.value;"><button class="opt-del" onclick="fbFields[${i}].options.splice(${oi},1);renderFormCanvas();">✕</button></div>`).join('')}
          <button class="add-opt-btn" style="margin-top:4px;" onclick="fbFields[${i}].options.push('Option '+(fbFields[${i}].options.length+1));renderFormCanvas();">＋ Add option</button>
        </div>`:''}
        <div class="form-preview-field">
          <label>${f.label||'Untitled question'} ${f.required?'<span class="req-star">*</span>':''}</label>
          ${previewHTML}
        </div>
        <div class="ffc-required"><input type="checkbox" ${f.required?'checked':''} onchange="fbFields[${i}].required=this.checked;renderFormCanvas();"><span>Required</span></div>
      </div>
    `;
  }).join('');
  canvas.querySelectorAll('.ffc-del').forEach(btn=>{
    btn.addEventListener('click',()=>{fbFields.splice(parseInt(btn.dataset.fi),1);renderFormCanvas();});
  });
}

