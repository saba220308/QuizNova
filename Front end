// Options
function resetOptionList(){qbOptions=[{text:'',correct:true},{text:'',correct:false},{text:'',correct:false},{text:'',correct:false}];renderOptionList();}
function renderOptionList(){
  const list=$('optList');
  list.innerHTML=qbOptions.map((o,i)=>`
    <div class="option-row">
      <input type="radio" class="opt-radio" name="correctOpt" ${o.correct?'checked':''} data-oi="${i}">
      <input class="opt-input" type="text" value="${o.text}" placeholder="Option ${String.fromCharCode(65+i)}" data-oi="${i}">
      ${qbOptions.length>2?`<button class="opt-del" data-oi="${i}">✕</button>`:''}
    </div>
  `).join('');
  list.querySelectorAll('.opt-radio').forEach(r=>r.addEventListener('change',()=>{qbOptions.forEach((o,i)=>o.correct=i===parseInt(r.dataset.oi));}));
  list.querySelectorAll('.opt-input').forEach(inp=>inp.addEventListener('input',()=>{qbOptions[parseInt(inp.dataset.oi)].text=inp.value;}));
  list.querySelectorAll('.opt-del').forEach(btn=>btn.addEventListener('click',()=>{qbOptions.splice(parseInt(btn.dataset.oi),1);renderOptionList();}));
}
$('addOptBtn').addEventListener('click',()=>{if(qbOptions.length<6){qbOptions.push({text:'',correct:false});renderOptionList();}});
renderOptionList();

$('addQBtn').addEventListener('click',()=>{
  clearMsg('aqMsg');
  if(qCurrentType==='mcq'){
    const text=$('aq-text').value.trim();
    if(!text){msg('aqMsg','Enter a question.');return;}
    if(qbOptions.some(o=>!o.text.trim())){msg('aqMsg','Fill in all options.');return;}
    if(!qbOptions.some(o=>o.correct)){msg('aqMsg','Mark a correct answer.');return;}
    qbQuestions.push({id:genId(),type:'mcq',text,options:qbOptions.map(o=>({...o}))});
    $('aq-text').value='';resetOptionList();
  } else {
    const text=$('tf-text').value.trim();
    if(!text){msg('aqMsg','Enter a statement.');return;}
    const ans=$('tf-ans').value==='true';
    qbQuestions.push({id:genId(),type:'tf',text,options:[{text:'True',correct:ans},{text:'False',correct:!ans}]});
    $('tf-text').value='';
  }
  renderQList();
});

function renderQList(){
  $('qCountLbl').textContent=qbQuestions.length;
  $('qEmpty').style.display=qbQuestions.length?'none':'block';
  const list=$('qList');
  list.innerHTML=qbQuestions.map((q,i)=>`
    <div class="q-item">
      <button class="q-item-del" data-qi="${i}">✕</button>
      <div class="q-item-head">
        <span class="q-num">Q${i+1}</span>
        <span class="q-type-lbl">${q.type==='mcq'?'Multiple Choice':'True/False'}</span>
      </div>
      <div class="q-text">${q.text}</div>
      <div class="q-options">
        ${q.options.map(o=>`<div class="q-opt ${o.correct?'correct':'wrong'}"><span class="oi">${o.correct?'✓':'○'}</span>${o.text}</div>`).join('')}
      </div>
    </div>
  `).join('');
  list.querySelectorAll('.q-item-del').forEach(btn=>{
    btn.addEventListener('click',()=>{qbQuestions.splice(parseInt(btn.dataset.qi),1);renderQList();});
  });
}

// Bulk import
$('bulkImportBtn').addEventListener('click',()=>{
  clearMsg('bulkMsg');
  const raw=$('bulkText').value.trim();
  if(!raw){msg('bulkMsg','Paste some questions first.','err');return;}
  const blocks=raw.split(/\n\s*\n/).filter(b=>b.trim());
  let count=0;
  blocks.forEach(block=>{
    const lines=block.trim().split('\n').map(l=>l.trim()).filter(Boolean);
    if(lines.length<3)return;
    const qText=lines[0];
    const opts=lines.slice(1).map(l=>({text:l.startsWith('*')?l.slice(1).trim():l,correct:l.startsWith('*')}));
    if(!opts.some(o=>o.correct))opts[0].correct=true;
    qbQuestions.push({id:genId(),type:'mcq',text:qText,options:opts});
    count++;
  });
  if(count){msg('bulkMsg',`✓ Imported ${count} question${count>1?'s':''}!`,'ok');renderQList();$('bulkText').value='';}
  else msg('bulkMsg','Could not parse questions. Check the format.','err');
});

