// ══ QUIZ PLAY ══
let playQ=[],playCur=0,playScore=0,playAnswered=false,playTimer=null,playTLeft=15,playTest=null,playCls=null;
const CIRC=2*Math.PI*22, LBLS=['A','B','C','D','E','F'];

function startQuiz(test,cls){
  playTest=test;playCls=cls;
  playQ=[...test.questions].sort(()=>Math.random()-.5);
  playCur=0;playScore=0;playAnswered=false;
  $('qDot').style.background=cls.color;
  $('qClassName').textContent=cls.name;
  showSPanel('sQuiz');loadQ();
}
function loadQ(){
  playAnswered=false;
  const q=playQ[playCur],tot=playQ.length;
  $('qProgressFill').style.width=(playCur/tot*100)+'%';
  $('arcFill').style.strokeDashoffset=CIRC-(playCur/tot)*CIRC;
  $('arcLabel').textContent=`${playCur+1}/${tot}`;
  $('catTag').textContent=q.type==='tf'?'True/False':'MCQ';
  $('quizQ').textContent=q.text;
  $('ansGrid').innerHTML='';
  const opts=q.options;
  opts.forEach((o,i)=>{
    const b=document.createElement('button');
    b.className='ans-btn';
    b.innerHTML=`<span class="ans-lbl">${LBLS[i]}</span>${o.text}`;
    b.addEventListener('click',()=>pickAns(i));
    $('ansGrid').appendChild(b);
  });
  $('qFb').className='q-fb';$('nextQBtn').className='next-q-btn';
  resetTimer();startTimer(playTest.timeLimit||15);
}
function startTimer(secs){playTLeft=secs;updTimer();playTimer=setInterval(()=>{playTLeft--;updTimer();if(playTLeft<=0){clearInterval(playTimer);if(!playAnswered)timeUp();}},1000);}
function updTimer(){$('timerFill').style.width=(playTLeft/(playTest.timeLimit||15)*100)+'%';$('timerFill').style.background=playTLeft<=5?'#EF4444':playTLeft<=8?'#F59E0B':'#3B6FFF';$('timerNum').textContent=playTLeft;}
function resetTimer(){clearInterval(playTimer);$('timerFill').style.width='100%';$('timerFill').style.background='#3B6FFF';$('timerNum').textContent=playTest.timeLimit||15;}
function timeUp(){playAnswered=true;const btns=$('ansGrid').querySelectorAll('.ans-btn');btns.forEach(b=>b.disabled=true);const ci=playQ[playCur].options.findIndex(o=>o.correct);if(ci>-1)btns[ci].classList.add('correct');btns.forEach((b,i)=>{if(i!==ci)b.classList.add('reveal');});showQFb(false,"Time's up!");$('nextQBtn').className='next-q-btn on';}
function pickAns(i){
  if(playAnswered)return;playAnswered=true;clearInterval(playTimer);
  const ci=playQ[playCur].options.findIndex(o=>o.correct);
  const btns=$('ansGrid').querySelectorAll('.ans-btn');
  btns.forEach(b=>b.disabled=true);
  if(i===ci){playScore++;btns[i].classList.add('correct');showQFb(true,'Correct!');}
  else{btns[i].classList.add('wrong');btns[ci].classList.add('correct');btns.forEach((b,j)=>{if(j!==i&&j!==ci)b.classList.add('reveal');});showQFb(false,`Not quite — the answer is ${playQ[playCur].options[ci].text}.`);}
  $('nextQBtn').className='next-q-btn on';
}
function showQFb(ok,t){$('qFbIcon').textContent=ok?'✓':'✕';$('qFbText').textContent=t;$('qFb').className=`q-fb ${ok?'c':'w'} on`;}
$('nextQBtn').addEventListener('click',()=>{playCur++;if(playCur>=playQ.length)endQuiz();else loadQ();});
$('qExitBtn').addEventListener('click',()=>{clearInterval(playTimer);showSPanel('sJoin');});

function endQuiz(){
  $('arcFill').style.strokeDashoffset=0;$('qProgressFill').style.width='100%';
  const results=gRes();const r=results.find(x=>x.testId===playTest.id&&x.studentEmail===CU.e);
  if(r){r.score=playScore;r.total=playQ.length;sRes(results);}
  showSPanel('sScore');
  const pct=playScore/playQ.length;
  let emoji,hl;
  if(pct===1){emoji='🏆';hl='Perfect score!';}else if(pct>=.8){emoji='🎉';hl='Excellent!';}else if(pct>=.6){emoji='👍';hl='Good job!';}else if(pct>=.4){emoji='🤔';hl='Keep practicing!';}else{emoji='📚';hl='Study up!';}
  $('scEmoji').textContent=emoji;$('scHeadline').textContent=hl;$('scSub').textContent='Well done, '+CU.fn+'!';$('scClass').textContent='✦ '+playCls.name+' · '+playTest.title;
  $('scDen').textContent='out of '+playQ.length+' correct';$('scBig').textContent=0;
  let n=0;const step=()=>{if(n<playScore){n++;$('scBig').textContent=n;requestAnimationFrame(step);}};requestAnimationFrame(step);
}
$('scAgain').addEventListener('click',()=>startQuiz(playTest,playCls));

// ══ FORM PLAY ══
let playForm=null,playFormCls=null;
function startForm(test,cls){
  playForm=test;playFormCls=cls;
  $('formPlayTitle').textContent=test.title;
  $('formPlayDesc').textContent=test.desc||'';
  const fields=$('formPlayFields');
  fields.innerHTML=test.fields.map((f,i)=>{
    const req=f.required?'<span class="req"> *</span>':'';
    let inputHTML='';
    if(f.type==='short') inputHTML=`<input class="form-play-input" id="ff_${i}" placeholder="Your answer">`;
    else if(f.type==='para') inputHTML=`<textarea class="form-play-textarea" id="ff_${i}" placeholder="Your answer"></textarea>`;
    else if(f.type==='scale') inputHTML=`<div style="display:flex;gap:8px;flex-wrap:wrap;">${[1,2,3,4,5].map(n=>`<label style="display:flex;flex-direction:column;align-items:center;gap:5px;cursor:pointer;"><input type="radio" name="scale_${i}" value="${n}" style="accent-color:var(--blue);"> <span style="font-size:.8rem;">${n}</span></label>`).join('')}</div>`;
    else if(f.type==='drop') inputHTML=`<select class="form-play-select" id="ff_${i}"><option value="">Choose…</option>${(f.options||[]).map(o=>`<option>${o}</option>`).join('')}</select>`;
    else if(['mcq','check'].includes(f.type)){
      const itype=f.type==='check'?'checkbox':'radio';
      inputHTML=(f.options||[]).map(o=>`<div class="form-play-option"><input type="${itype}" name="fp_${i}" value="${o}"><span>${o}</span></div>`).join('');
    }
    return `<div class="form-play-field"><label>${f.label||'Untitled'}${req}</label>${inputHTML}</div>`;
  }).join('');
  $('formPlayMsg').className='msg-bar';
  showSPanel('sForm');
}
$('submitFormBtn').addEventListener('click',()=>{
  // basic required check
  let ok=true;
  playForm.fields.forEach((f,i)=>{
    if(!f.required)return;
    const el=$('ff_'+i);
    if(el&&!el.value.trim()){ok=false;}
  });
  if(!ok){msg('formPlayMsg','Please fill in all required fields.','err');return;}
  // save response
  const results=gRes();const r=results.find(x=>x.testId===playForm.id&&x.studentEmail===CU.e);
  if(r){r.score='Submitted';r.total='—';sRes(results);}
  showSPanel('sFormDone');
});
</script>
