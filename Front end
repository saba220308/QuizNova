// ══ OVERVIEW ══
function renderOverview(){
  const hour=new Date().getHours();
  const greet=hour<12?'Good morning':hour<17?'Good afternoon':'Good evening';
  $('ovTitle').textContent=(hour<12?'Good morning':hour<17?'Good afternoon':'Good evening')+', '+CU.fn+'! 👋';
  const myTests=gTests().filter(t=>t.owner===CU.e);
  const myClasses=gC().filter(c=>c.owner===CU.e);
  const myStudents=[...new Set(myClasses.flatMap(c=>c.students||[]))];
  $('ovTests').textContent=myTests.length;
  $('ovClasses').textContent=myClasses.length;
  $('ovStudents').textContent=myStudents.length;
  // active tests
  const active=myTests.filter(t=>t.active);
  $('ovActiveTests').innerHTML=active.length
    ?active.map(t=>`<div class="card" style="padding:14px 16px;margin-bottom:8px;display:flex;align-items:center;justify-content:space-between;gap:12px;"><div><div style="font-weight:600;font-size:.88rem;">${t.title}</div><div style="color:var(--slate);font-size:.74rem;margin-top:3px;">${t.type==='quiz'?'Quiz':'Form'} · ${t.qCount||0} questions</div></div><span class="status-pill done">Active</span></div>`).join('')
    :'<div style="color:var(--slate);font-size:.82rem;padding:10px 0;">No active tests. Go to My Tests to activate one.</div>';
  // recent results
  const myClassCodes=myClasses.map(c=>c.code);
  const recent=gRes().filter(r=>myClassCodes.includes(r.classCode)).slice(-5).reverse();
  $('ovRecentResults').innerHTML=recent.length
    ?recent.map(r=>`<div class="card" style="padding:12px 16px;margin-bottom:8px;display:flex;align-items:center;justify-content:space-between;gap:12px;"><div><div style="font-weight:500;font-size:.86rem;">${r.studentName}</div><div style="color:var(--slate);font-size:.73rem;">${r.testTitle||'Quiz'}</div></div><div style="font-family:'Syne',sans-serif;font-weight:700;font-size:.85rem;color:var(--amber);">${r.score!=null?r.score+'/'+r.total:'Pending'}</div></div>`).join('')
    :'<div style="color:var(--slate);font-size:.82rem;padding:10px 0;">No results yet.</div>';
}

// ══ TEST GRID ══
function renderTestGrid(){
  const myTests=gTests().filter(t=>t.owner===CU.e);
  const grid=$('testGrid');
  if(!myTests.length){grid.innerHTML='<div class="empty-qs" style="grid-column:1/-1;"><span>📋</span>No tests yet. Create a quiz or form above!</div>';return;}
  grid.innerHTML=myTests.map(t=>`
    <div class="card test-card">
      <div class="test-accent" style="background:${t.type==='quiz'?'linear-gradient(90deg,var(--blue),var(--violet))':'linear-gradient(90deg,#7C3AED,#EC4899)'}"></div>
      <div class="test-card-head">
        <div class="test-title">${t.title}</div>
        <span class="test-type-badge ${t.type}">${t.type==='quiz'?'Quiz':'Form'}</span>
      </div>
      <div class="test-meta">
        <span>❓ ${t.qCount||0} questions</span>
        <span>🏫 ${t.classCode?t.classCode:'Unassigned'}</span>
      </div>
      <div class="test-footer">
        <div class="toggle-wrap">
          <label class="toggle"><input type="checkbox" ${t.active?'checked':''} data-tid="${t.id}" class="test-toggle"><div class="toggle-track"></div><div class="toggle-thumb"></div></label>
          <span class="toggle-lbl">${t.active?'Active':'Inactive'}</span>
        </div>
        <div class="test-actions">
          <button class="icon-btn del" data-tid="${t.id}" title="Delete">🗑</button>
        </div>
      </div>
    </div>
  `).join('');
  grid.querySelectorAll('.test-toggle').forEach(cb=>{
    cb.addEventListener('change',()=>{
      const tests=gTests();const t=tests.find(x=>x.id===cb.dataset.tid);
      if(t){t.active=cb.checked;sTests(tests);}
      renderTestGrid();renderOverview();
    });
  });
  grid.querySelectorAll('.icon-btn.del').forEach(btn=>{
    btn.addEventListener('click',()=>{
      if(!confirm('Delete this test?'))return;
      sTests(gTests().filter(t=>t.id!==btn.dataset.tid));
      renderTestGrid();renderOverview();
    });
  });
}

// ══ QUIZ BUILDER ══
let qbQuestions=[], qbEditId=null, qCurrentType='mcq';
let qbOptions=[{text:'',correct:true},{text:'',correct:false},{text:'',correct:false},{text:'',correct:false}];

